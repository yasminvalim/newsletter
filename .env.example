# Copy to .env and fill in. Never commit .env.

# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=
# One repo, or several under the same owner (comma-separated)
GITHUB_REPO=

# GitLab (PAT with read_api). GITLAB_BASE_URL = instance root, e.g. https://gitlab.com (not a group URL).
GITLAB_TOKEN=
GITLAB_BASE_URL=https://gitlab.com
# Numeric id or URL-encoded path; comma-separated for several projects
GITLAB_PROJECT_ID=

# Jira Cloud (API token + email for basic auth)
JIRA_BASE_URL=
JIRA_EMAIL= 
JIRA_API_TOKEN= 
JIRA_PROJECT_KEY=

# Optional: priority field name and values (Jira-specific)
JIRA_PRIORITY_FIELD=priority
JIRA_PRIORITY_NAMES=Highest,High

# LLM — Gemini (optional; fetch works without this)
#
# Option A — Gemini Developer API (AI Studio API key):
# GOOGLE_API_KEY=
#
# Option B — Vertex AI (no API key): Application Default Credentials + project.
# Run: gcloud auth application-default login
# Enable "Vertex AI API" on the project. Then set:
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
#
# Use a model your route supports (Vertex: check region; e.g. gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash